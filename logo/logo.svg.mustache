<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 {{canvas_w}} {{canvas_h}}">
  <rect x="{{crown_x}}" y="{{crown_y}}" width="{{crown_w}}" height="{{crown_h}}" fill="{{hat_color}}"/>
  <rect x="{{brim_x}}"  y="{{brim_y}}"  width="{{brim_w}}"  height="{{brim_h}}"  fill="{{hat_color}}"/>
  <text x="{{brace_x}}" y="{{brace_y}}" font-size="{{brace_size}}" font-family="monospace" fill="{{brace_color}}">{}</text>
  <rect x="{{lens_l_x}}" y="{{lens_y}}" width="{{lens_w}}" height="{{lens_h}}" rx="{{lens_corner}}" fill="{{lens_color}}" opacity="{{lens_opacity}}"/>
  <rect x="{{lens_r_x}}" y="{{lens_y}}" width="{{lens_w}}" height="{{lens_h}}" rx="{{lens_corner}}" fill="{{lens_color}}" opacity="{{lens_opacity}}"/>
  <line x1="{{bridge_x1}}" y1="{{bridge_y}}" x2="{{bridge_x2}}" y2="{{bridge_y}}" stroke="{{bridge_color}}" stroke-width="2"/>
  <rect x="{{gun_x}}"    y="{{gun_y}}"    width="{{gun_w}}"    height="{{gun_h}}"    fill="{{gun_color}}"/>
  <rect x="{{barrel_x}}" y="{{barrel_y}}" width="{{barrel_w}}" height="{{barrel_h}}" fill="{{gun_color}}"/>
  <rect x="{{grip_x}}"   y="{{grip_y}}"   width="{{grip_w}}"   height="{{grip_h}}"   fill="{{gun_color}}"/>
</svg>
